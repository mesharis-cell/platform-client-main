# Docs tutorials screenshot harness — env template.
# Copy to .env.docs.local and edit. Used by playwright.docs.config.ts.
#
# All values below are the defaults used when the test stack is running
# locally against the seeded Kadence Demo tenant
# (see api/test/README.md for the API-side setup).

# URL the Playwright harness navigates to.
DOCS_CLIENT_BASE_URL=http://localhost:4002

# Credentials Alex Chen, the screenshot-only CLIENT user seeded by
# `bun run db:seed:test`. Kept in .env.local so they can be overridden
# if the seed ever changes without editing fixture code.
DOCS_CLIENT_EMAIL=alex.chen@kadence-demo.com
DOCS_CLIENT_PASSWORD=DocsPass!Client1
